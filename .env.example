ENVIRONMENT=local
SERVICE_NAME=ingestion-file
LOG_LEVEL=info
TRACE_ID=

HTTP_PORT=8080
METRICS_PORT=9090

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pipeline

POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/pipeline?sslmode=disable

S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_BUCKET_LANDING=landing
S3_BUCKET_PROCESSED=processed
S3_BUCKET_QUARANTINE=quarantine
